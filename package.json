{
  "name": "dise-o_de_interiores",
  "version": "0.9.0-rc.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "benchmark:walls": "tsx scripts/benchmark-wall-detection.ts",
    "benchmark:walls:check": "tsx scripts/benchmark-wall-detection.ts --check",
    "benchmark:paint": "tsx scripts/benchmark-paint-rendering.ts",
    "benchmark:paint:check": "tsx scripts/benchmark-paint-rendering.ts --check",
    "benchmark:performance": "tsx scripts/benchmark-performance.ts",
    "benchmark:stress": "node --expose-gc --import tsx scripts/stress-performance.ts",
    "performance:check": "tsx scripts/benchmark-performance.ts --check",
    "analyze": "next build --webpack && tsx scripts/analyze-bundle.ts"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "idb": "^8.0.3",
    "image-size": "^2.0.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
